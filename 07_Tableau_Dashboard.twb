      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1q56f1m1if7cm1143jm4518eu5jm].[avg:purchase_amount:qk]&quot;' value='AVG. PURCHASE AMOUNT' />
          <alias key='&quot;[federated.1q56f1m1if7cm1143jm4518eu5jm].[usr:Calculation_0915355884511235:qk]&quot;' value='TOTAL REVENUE' />
          <alias key='&quot;[federated.1q56f1m1if7cm1143jm4518eu5jm].[usr:Calculation_0915355884756996:qk]&quot;' value=' AVG REVIEW RATING' />
          <alias key='&quot;[federated.1q56f1m1if7cm1143jm4518eu5jm].[usr:Calculation_0915355893866501:qk]&quot;' value='SUBSCRIPTION STATUS' />
        </aliases>
      </column>
      <column caption='Calculation:-1 Revenue Category' datatype='string' name='[Calculation_0915355859476480]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [purchase_amount] &lt; 30 THEN &quot;Budget&quot;&#13;&#10;ELSEIF [purchase_amount] &lt; 60 THEN &quot;Standard&quot;&#13;&#10;ELSEIF [purchase_amount] &lt; 100 THEN &quot;Premium&quot;&#13;&#10;ELSE &quot;VIP&quot;&#13;&#10;END' />
      </column>
      <column caption='Calculation:-2 Customer Value' datatype='string' name='[Calculation_0915355881762817]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [subscription_status] = &quot;Yes&quot; AND [previous_purchases] &gt; 5 THEN&#13;&#10;&quot;High Value&quot;&#13;&#10;    ELSEIF  [previous_purchases] &gt;= 1 THEN &quot;Retained&quot;&#13;&#10;    ELSE &#13;&#10;        &quot;New&quot;&#13;&#10;END' />
      </column>
      <column caption='Calculation:-3 Shipping Speed' datatype='string' name='[Calculation_0915355883962370]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='If [shipping_type] IN (&quot;Express&quot;, &quot;Next Day Air&quot;)&#13;&#10;THEN &quot;Fast&quot;&#13;&#10;Elseif [shipping_type] = &quot;Standard&quot;&#13;&#10;Then &quot;standard&quot;&#13;&#10;ELSE &quot;Economy&quot;&#13;&#10;END' />
      </column>
      <column caption='Calculation:-4 Total Revenue ' datatype='integer' name='[Calculation_0915355884511235]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([purchase_amount])' />
      </column>
      <column caption='Calculation:-5 Avg Rating' datatype='real' name='[Calculation_0915355884756996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(AVG([review_rating]),2)' />
      </column>
      <column caption='Subscription Status CAL' datatype='real' name='[Calculation_0915355893866501]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM((If [subscription_status] = &quot;Yes&quot; THEN 1 ELSE 0 END)) /&#13;&#10;COUNTD([customer_id])' />
      </column>
      <column caption='Waterfall Size' datatype='integer' name='[Calculation_0915355902488584]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-[purchase_amount]' />
      </column>
      <column aggregation='CountD' caption='Customer Segment' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_0915355951206409]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [subscription_status] = &quot;Yes&quot; AND [previous_purchases] &gt; 5 &#13;&#10;        THEN &quot;High Value (Loyal Subscriber)&quot;&#13;&#10;    elseif [previous_purchases] &gt; 5 &#13;&#10;        THEN &quot;At Risk (Lapsed Loyal)&quot;&#13;&#10;    elseif [previous_purchases] &gt; 0 &#13;&#10;        THEN &quot;Retained&quot;&#13;&#10;    ELSE &quot;New&quot;&#13;&#10;END' />
      </column>
      <column caption='Update Timestamp' datatype='datetime' default-format='*mm/dd/yyyy hh:mm' name='[Calculation_0971431363612672]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='NOW()' />
      </column>
      <column caption='Coloring above average' datatype='boolean' name='[Calculation_1556921078276098]' role='measure' type='nominal'>
        <calculation class='tableau' formula='AVG([purchase_amount]) &gt; WINDOW_AVG(AVG([purchase_amount]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Shipping Type Filter' datatype='string' name='[Calculation_1556921088536579]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [shipping_type] = [shipping_type] THEN &quot;ALL&quot; &#13;&#10;END' />
      </column>
      <column caption='customer' datatype='table' name='[__tableau_internal_object_id__].[customer_4C09CE65135D479BBB03268B77E3EDEB]' role='measure' type='quantitative' />
      <column caption='Age' datatype='integer' name='[age]' role='measure' type='quantitative' />
